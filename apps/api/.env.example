# ── Server ──
PORT=3000

# ── Frontend URL (for OAuth redirect) ──
FRONTEND_URL=http://localhost:5173

# ── Google OAuth (required for Google Docs export) ──
# Create credentials: https://console.cloud.google.com/apis/credentials
# Scopes needed:
#   - https://www.googleapis.com/auth/documents
#   - https://www.googleapis.com/auth/drive.file
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ── Google Docs Template (required for template-driven export) ──
# This template provides the cover, kata pengantar, and DAFTAR ISI sections.
# The report body is inserted after the DAFTAR ISI anchor.
# Template must have "Anyone with the link" view access.
# GOOGLE_DOCS_TEMPLATE_ID=1HGK7-rWfTckdPXzjgBgurGyQhWb5X2R4

# ── Database (optional, defaults to ./db/dev.db) ──
# DATABASE_URL=file:./db/dev.db
