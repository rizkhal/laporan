{
  "name": "monthly-dev-report",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c green,yellow \"npm -w apps/api run dev\" \"npm -w apps/web run dev\"",
    "build": "npm run build -w apps/web",
    "db:push": "npm run db:push -w apps/api",
    "db:generate": "npm run db:generate -w apps/api",
    "test": "npm run test -w apps/api",
    "db:studio": "npm run db:studio -w apps/api",
    "db:migrate": "npx tsx apps/api/db/migrate-workspaces.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "markdown-docx": "^1.6.0"
  }
}
